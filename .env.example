# Frontend public configuration
NEXT_PUBLIC_CHAIN_ID=1979
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_RITE_ADDRESS=

# Server-side Ritual configuration.
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITE_ADDRESS=

# Production storage on Vercel. Install Upstash Redis from Vercel Marketplace
# or set these manually. Local dev falls back to WORKFLOW_STORE_PATH.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
WORKFLOW_STORE_PATH=./data/workflows.json

# Used by server-side sealing, never exposed to the browser.
PRIVATE_KEY=
